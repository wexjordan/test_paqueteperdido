#!/usr/bin/env python3
"""
netmon-server: Servidor echo consolidado TCP + UDP.

Escucha en el mismo puerto TCP y UDP. Devuelve los bytes recibidos.
Diseñado para ser usado como destino por los monitores de la suite netmon.
"""

import argparse
import socket
import threading
import signal
import sys

RUNNING = True

def handle_tcp_client(conn, addr):
    conn.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
    conn.setsockopt(socket.SOL_SOCKET, socket.SO_KEEPALIVE, 1)
    try:
        while True:
            data = conn.recv(4096)
            if not data:
                break
            conn.sendall(data)
    except (ConnectionResetError, BrokenPipeError, OSError):
        pass
    finally:
        try:
            conn.close()
        except Exception:
            pass

def tcp_server(host, port):
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    sock.bind((host, port))
    sock.listen(128)
    sock.settimeout(1.0)
    print(f"[+] TCP echo escuchando en {host}:{port}", flush=True)
    while RUNNING:
        try:
            conn, addr = sock.accept()
            t = threading.Thread(target=handle_tcp_client, args=(conn, addr),
                                 daemon=True)
            t.start()
        except socket.timeout:
            continue
        except OSError:
            break
    sock.close()

def udp_server(host, port):
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_RCVBUF, 4 * 1024 * 1024)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_SNDBUF, 4 * 1024 * 1024)
    sock.bind((host, port))
    sock.settimeout(1.0)
    print(f"[+] UDP echo escuchando en {host}:{port}", flush=True)
    while RUNNING:
        try:
            data, addr = sock.recvfrom(2048)
            sock.sendto(data, addr)
        except socket.timeout:
            continue
        except OSError:
            break
    sock.close()

def main():
    global RUNNING
    p = argparse.ArgumentParser(description="netmon echo server (TCP+UDP)")
    p.add_argument("--host", default="0.0.0.0")
    p.add_argument("--port", type=int, default=9999)
    args = p.parse_args()

    def shutdown(signum, frame):
        global RUNNING
        print("\n[+] Cerrando servidor...", flush=True)
        RUNNING = False
    signal.signal(signal.SIGINT, shutdown)
    signal.signal(signal.SIGTERM, shutdown)

    t_tcp = threading.Thread(target=tcp_server, args=(args.host, args.port),
                             daemon=True)
    t_udp = threading.Thread(target=udp_server, args=(args.host, args.port),
                             daemon=True)
    t_tcp.start()
    t_udp.start()

    while RUNNING:
        try:
            t_tcp.join(timeout=1)
            t_udp.join(timeout=1)
        except KeyboardInterrupt:
            RUNNING = False

if __name__ == "__main__":
    main()
