#!/usr/bin/env python3
"""
netmon-html-report: Genera un reporte HTML autocontenido con gráficos
interactivos y todas las horas convertidas a Colombia (UTC-4).

USO:
    netmon-html-report --day 2026-05-14
    netmon-html-report --day 2026-05-14 --output /tmp/reporte.html
    netmon-html-report --day 2026-05-14 --base-dir /var/log/netmon
"""

import argparse
import csv
import json
import sys
import os
from pathlib import Path
from datetime import datetime, timedelta, timezone
from collections import defaultdict
import html

# Zona horaria Colombia (UTC-4)
COLOMBIA_OFFSET = timedelta(hours=-4)
COLOMBIA_TZ = timezone(COLOMBIA_OFFSET, "Colombia")


def parse_ts(s):
    """Parse ISO timestamp UTC y devuelve datetime con tz."""
    s = s.rstrip("Z")
    try:
        dt = datetime.fromisoformat(s)
    except ValueError:
        dt = datetime.strptime(s.split(".")[0], "%Y-%m-%dT%H:%M:%S")
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    return dt


def to_local(dt):
    """Convierte datetime UTC a hora Colombia."""
    return dt.astimezone(COLOMBIA_TZ)


def fmt_local(dt, fmt="%Y-%m-%d %H:%M:%S"):
    return to_local(dt).strftime(fmt)


def load_latency_csv(path):
    rows = []
    if not Path(path).exists():
        return rows
    with open(path) as f:
        reader = csv.DictReader(f)
        for r in reader:
            try:
                r["timestamp"] = parse_ts(r["timestamp_utc"])
                for k in ["min_us","max_us","mean_us","p50_us","p95_us",
                         "p99_us","stddev_us","jitter_us","loss_pct"]:
                    r[k] = float(r[k])
                r["samples"] = int(r["samples"])
                rows.append(r)
            except (KeyError, ValueError):
                continue
    return rows


def load_udp_csv(path):
    rows = []
    if not Path(path).exists():
        return rows
    with open(path) as f:
        reader = csv.DictReader(f)
        for r in reader:
            try:
                r["timestamp"] = parse_ts(r["timestamp_utc"])
                for k in ["loss_pct","min_us","p50_us","p95_us","p99_us",
                         "max_us","jitter_us","longest_cut_ms"]:
                    r[k] = float(r[k])
                for k in ["sent","received","lost","out_of_order","microcuts"]:
                    r[k] = int(r[k])
                rows.append(r)
            except (KeyError, ValueError):
                continue
    return rows


def load_microcuts_log(path):
    events = []
    if not Path(path).exists():
        return events
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split("\t")
            if len(parts) < 4:
                continue
            ev = {"timestamp": parse_ts(parts[0])}
            for p in parts[1:]:
                if "=" in p:
                    k, v = p.split("=", 1)
                    ev[k] = v
            try:
                ev["duration_ms"] = float(ev.get("duration_ms", 0))
                ev["lost"] = int(ev.get("lost", 0))
            except ValueError:
                continue
            events.append(ev)
    return events


def load_events(path):
    events = []
    if not Path(path).exists():
        return events
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split("\t", 2)
            if len(parts) < 3:
                continue
            try:
                events.append({
                    "timestamp": parse_ts(parts[0]),
                    "level": parts[1],
                    "msg": parts[2],
                })
            except ValueError:
                continue
    return events


def load_disconnects(path):
    events = []
    if not Path(path).exists():
        return events
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            parts = line.split("\t")
            if len(parts) < 2:
                continue
            ev = {"timestamp": parse_ts(parts[0])}
            for p in parts[1:]:
                if "=" in p:
                    k, v = p.split("=", 1)
                    ev[k] = v
            events.append(ev)
    return events


def percentile(sd, p):
    if not sd:
        return 0
    sd = sorted(sd)
    k = (len(sd)-1)*(p/100.0)
    f = int(k); c = min(f+1, len(sd)-1)
    if f == c: return sd[f]
    return sd[f] + (sd[c]-sd[f])*(k-f)


def build_data(base_dir, day):
    base = Path(base_dir)
    lat = load_latency_csv(base / "latency" / f"metrics-{day}.csv")
    udp = load_udp_csv(base / "microcuts" / f"metrics-{day}.csv")
    cuts = load_microcuts_log(base / "microcuts" / f"microcuts-{day}.log")
    lat_events = load_events(base / "latency" / f"events-{day}.log")
    udp_events = load_events(base / "microcuts" / f"events-{day}.log")
    discs = load_disconnects(base / "connections" / f"disconnects-{day}.log")

    return {
        "latency": lat,
        "udp": udp,
        "microcuts": cuts,
        "latency_events": lat_events,
        "udp_events": udp_events,
        "disconnects": discs,
    }


def compute_summary(data):
    lat = data["latency"]
    udp = data["udp"]
    cuts = data["microcuts"]
    discs = data["disconnects"]

    summary = {
        "ventanas_lat": len(lat),
        "ventanas_udp": len(udp),
        "total_microcuts": len(cuts),
        "total_disconnects": len([d for d in discs if d.get("type") == "DISCONNECT"]),
        "total_stalls": len([d for d in discs if d.get("type") == "STALL"]),
        "total_reconnects": len([d for d in discs if d.get("type") == "RECONNECT"]),
    }

    if lat:
        p50s = [r["p50_us"] for r in lat]
        p99s = [r["p99_us"] for r in lat]
        maxs = [r["max_us"] for r in lat]
        mins = [r["min_us"] for r in lat]
        summary["lat_p50_median"] = percentile(p50s, 50) / 1000  # ms
        summary["lat_p99_median"] = percentile(p99s, 50) / 1000
        summary["lat_p99_worst"] = max(p99s) / 1000
        summary["lat_max_worst"] = max(maxs) / 1000
        summary["lat_min_abs"] = min(mins) / 1000
        summary["lat_max_abs"] = max(maxs) / 1000

    if udp:
        total_sent = sum(r["sent"] for r in udp)
        total_lost = sum(r["lost"] for r in udp)
        summary["udp_sent"] = total_sent
        summary["udp_lost"] = total_lost
        summary["udp_loss_pct"] = (total_lost / total_sent * 100) if total_sent else 0

    if cuts:
        durations = [c["duration_ms"] for c in cuts]
        summary["cut_longest_ms"] = max(durations)
        summary["cut_dist"] = {
            "<5ms": sum(1 for d in durations if d < 5),
            "5-10ms": sum(1 for d in durations if 5 <= d < 10),
            "10-50ms": sum(1 for d in durations if 10 <= d < 50),
            "50-100ms": sum(1 for d in durations if 50 <= d < 100),
            "100-500ms": sum(1 for d in durations if 100 <= d < 500),
            ">=500ms": sum(1 for d in durations if d >= 500),
        }

    return summary


def build_hourly_stats(data):
    """Estadísticas por hora en hora Colombia."""
    by_hour = defaultdict(lambda: {
        "lat_p99": [], "lat_max": [], "microcuts": 0,
        "cut_longest": 0, "disconnects": 0,
    })
    for r in data["latency"]:
        h = to_local(r["timestamp"]).strftime("%H:00")
        by_hour[h]["lat_p99"].append(r["p99_us"])
        by_hour[h]["lat_max"].append(r["max_us"])
    for c in data["microcuts"]:
        h = to_local(c["timestamp"]).strftime("%H:00")
        by_hour[h]["microcuts"] += 1
        if c["duration_ms"] > by_hour[h]["cut_longest"]:
            by_hour[h]["cut_longest"] = c["duration_ms"]
    for d in data["disconnects"]:
        if d.get("type") in ("DISCONNECT", "STALL"):
            h = to_local(d["timestamp"]).strftime("%H:00")
            by_hour[h]["disconnects"] += 1

    result = {}
    for h, v in by_hour.items():
        result[h] = {
            "p99_median_ms": percentile(v["lat_p99"], 50)/1000 if v["lat_p99"] else 0,
            "max_ms": max(v["lat_max"])/1000 if v["lat_max"] else 0,
            "microcuts": v["microcuts"],
            "cut_longest_ms": v["cut_longest"],
            "disconnects": v["disconnects"],
        }
    return result


def detect_critical_events(data, threshold_ms=100):
    """Eventos críticos: microcortes >= threshold ms o disconnects."""
    critical = []
    for c in data["microcuts"]:
        if c["duration_ms"] >= threshold_ms:
            critical.append({
                "ts": c["timestamp"],
                "kind": "microcut",
                "severity": "high" if c["duration_ms"] >= 500 else "medium",
                "detail": f"Microcorte de {c['duration_ms']:.0f} ms ({c['lost']} paquetes UDP perdidos)",
                "duration_ms": c["duration_ms"],
            })
    for d in data["disconnects"]:
        if d.get("type") == "DISCONNECT":
            critical.append({
                "ts": d["timestamp"],
                "kind": "disconnect",
                "severity": "high",
                "detail": f"Caída TCP en conn={d.get('conn','?')} ({d.get('error','?')})",
                "duration_ms": 0,
            })
        elif d.get("type") == "STALL":
            critical.append({
                "ts": d["timestamp"],
                "kind": "stall",
                "severity": "medium",
                "detail": f"Stall TCP en conn={d.get('conn','?')}",
                "duration_ms": 0,
            })
    critical.sort(key=lambda x: x["ts"])
    return critical


