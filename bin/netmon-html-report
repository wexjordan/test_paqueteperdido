def render_html(data, day, base_dir, udp_rate=1000):
    summary = compute_summary(data)
    hourly = build_hourly_stats(data)
    critical = detect_critical_events(data, threshold_ms=100)

    # === KPI CARDS ===
    kpi_html = []

    if "lat_p50_median" in summary:
        kpi_html.append(f'''
          <div class="kpi accent">
            <div class="label">Latencia mediana (p50)</div>
            <div class="value">{summary["lat_p50_median"]:.1f}<span class="unit">ms</span></div>
            <div class="note">RTT típico del enlace</div>
          </div>
        ''')
        kpi_html.append(f'''
          <div class="kpi blue">
            <div class="label">p99 mediano</div>
            <div class="value">{summary["lat_p99_median"]:.1f}<span class="unit">ms</span></div>
            <div class="note">El 1% peor en una ventana típica</div>
          </div>
        ''')
        kpi_html.append(f'''
          <div class="kpi red">
            <div class="label">Peor pico del día</div>
            <div class="value">{summary["lat_max_worst"]:.1f}<span class="unit">ms</span></div>
            <div class="note">Evento puntual más extremo</div>
          </div>
        ''')

    if "udp_loss_pct" in summary:
        loss = summary["udp_loss_pct"]
        loss_class = "green" if loss < 0.01 else "yellow" if loss < 0.1 else "red"
        loss_badge = "ok" if loss < 0.01 else "warn" if loss < 0.1 else "bad"
        loss_text = "Excelente" if loss < 0.01 else "Aceptable" if loss < 0.1 else "Atención"
        kpi_html.append(f'''
          <div class="kpi {loss_class}">
            <div class="label">Pérdida UDP global</div>
            <div class="value">{loss:.4f}<span class="unit">%</span></div>
            <span class="badge {loss_badge}">{loss_text}</span>
          </div>
        ''')
        kpi_html.append(f'''
          <div class="kpi blue">
            <div class="label">Paquetes UDP procesados</div>
            <div class="value">{summary["udp_sent"]/1_000_000:.1f}<span class="unit">M</span></div>
            <div class="note">{summary["udp_sent"]:,} totales</div>
          </div>
        ''')

    if summary["total_microcuts"] > 0:
        cuts_class = "green" if summary["total_microcuts"] < 20 else "yellow" if summary["total_microcuts"] < 100 else "red"
        kpi_html.append(f'''
          <div class="kpi {cuts_class}">
            <div class="label">Microcortes detectados</div>
            <div class="value">{summary["total_microcuts"]}</div>
            <div class="note">Más largo: {summary.get("cut_longest_ms", 0):.0f} ms</div>
          </div>
        ''')

    disc_count = summary["total_disconnects"]
    disc_class = "green" if disc_count == 0 else "red"
    disc_badge = "ok" if disc_count == 0 else "bad"
    disc_text = "Estable" if disc_count == 0 else "Inestable"
    kpi_html.append(f'''
      <div class="kpi {disc_class}">
        <div class="label">Caídas de conexiones TCP</div>
        <div class="value">{disc_count}</div>
        <span class="badge {disc_badge}">{disc_text}</span>
      </div>
    ''')

    # === EXECUTIVE SUMMARY ===
    # Determinar veredicto global
    if summary["total_disconnects"] == 0 and summary["total_microcuts"] < 20:
        verdict_class = "green"
        verdict_title = "✓ Enlace saludable"
        verdict_body = "El enlace operó establemente durante todo el período. No se detectaron caídas TCP y la pérdida UDP es muy baja. Las aplicaciones productivas no debieron notar incidentes."
    elif summary["total_disconnects"] == 0:
        verdict_class = "yellow"
        verdict_title = "⚠ Enlace estable con glitches UDP"
        verdict_body = f"Las conexiones TCP no se cayeron en todo el período, lo cual es excelente. Sin embargo, se detectaron {summary['total_microcuts']} microcortes UDP, varios de los cuales podrían haber afectado aplicaciones de tiempo real (VoIP, video, streaming). Aplicaciones TCP tradicionales (web, BD, APIs) no fueron afectadas."
    else:
        verdict_class = "red"
        verdict_title = "✗ Enlace con incidentes serios"
        verdict_body = f"Se detectaron {summary['total_disconnects']} caídas de conexiones TCP, indicando problemas de red que afectaron aplicaciones productivas. Requiere investigación inmediata."

    exec_summary = f'''
      <div class="info-box {verdict_class}">
        <h3>{verdict_title}</h3>
        <p>{verdict_body}</p>
      </div>
    '''

    # === HEATMAP ===
    heatmap_cells = []
    for h in range(24):
        h_str = f"{h:02d}:00"
        stats = hourly.get(h_str, {"microcuts": 0, "disconnects": 0,
                                    "p99_median_ms": 0, "cut_longest_ms": 0, "max_ms": 0})
        cuts = stats["microcuts"]
        discs = stats["disconnects"]
        # Determinar nivel
        if discs > 0:
            level = "l4"
        elif cuts > 10:
            level = "l4"
        elif cuts > 3:
            level = "l3"
        elif cuts > 0:
            level = "l2"
        elif stats["p99_median_ms"] > 0:
            level = "l1"
        else:
            level = "l0"
        tooltip = (f"{h_str} Col.<br>"
                   f"p99: {stats['p99_median_ms']:.0f}ms<br>"
                   f"max: {stats['max_ms']:.0f}ms<br>"
                   f"µcuts: {cuts} (peor: {stats['cut_longest_ms']:.0f}ms)<br>"
                   f"discs: {discs}")
        heatmap_cells.append(
            f'<div class="hm-cell {level}">{h:02d}<div class="tooltip">{tooltip}</div></div>'
        )
    heatmap_html = "".join(heatmap_cells)

    # === HOURLY TABLE ===
    hourly_rows = []
    for h in range(24):
        h_str = f"{h:02d}:00"
        if h_str not in hourly:
            continue
        stats = hourly[h_str]
        # UTC equivalente
        utc_hour = (h + 4) % 24
        utc_str = f"{utc_hour:02d}:00"

        # Color del p99
        p99 = stats["p99_median_ms"]
        max_v = stats["max_ms"]
        cuts = stats["microcuts"]
        discs = stats["disconnects"]

        max_color = ""
        if max_v > 200:
            max_color = "color: var(--red); font-weight: 600"
        elif max_v > 100:
            max_color = "color: var(--yellow)"

        cuts_color = ""
        if cuts > 10:
            cuts_color = "color: var(--red); font-weight: 600"
        elif cuts > 3:
            cuts_color = "color: var(--yellow)"

        discs_color = "color: var(--red); font-weight: 600" if discs > 0 else "color: var(--text-dimmer)"

        hourly_rows.append(f'''
          <tr>
            <td><strong>{h_str}</strong></td>
            <td style="color: var(--text-dim)">{utc_str} UTC</td>
            <td style="text-align:right">{p99:.1f} ms</td>
            <td style="text-align:right; {max_color}">{max_v:.1f} ms</td>
            <td style="text-align:right; {cuts_color}">{cuts}</td>
            <td style="text-align:right">{stats["cut_longest_ms"]:.0f} ms</td>
            <td style="text-align:right; {discs_color}">{discs}</td>
          </tr>
        ''')

    # === CRITICAL EVENTS ===
    if critical:
        ev_rows = []
        for ev in critical:
            local = to_local(ev["ts"])
            sev_class = ev["severity"]
            kind_label = {"microcut": "MICROCORTE", "disconnect": "DESCONEXIÓN", "stall": "STALL"}.get(ev["kind"], ev["kind"].upper())
            ev_rows.append(f'''
              <tr>
                <td><strong>{local.strftime("%H:%M:%S")}</strong> Col.<br>
                    <span style="color: var(--text-dimmer); font-size: 0.75em">{ev["ts"].strftime("%H:%M:%S")} UTC</span></td>
                <td><span class="kind-tag">{kind_label}</span></td>
                <td><span class="severity-pill {sev_class}">{ev["severity"]}</span></td>
                <td>{html.escape(ev["detail"])}</td>
              </tr>
            ''')
        critical_html = f'''
          <div class="chart-box" style="padding:0">
            <table class="events-table">
              <thead>
                <tr>
                  <th>Hora</th>
                  <th>Tipo</th>
                  <th>Severidad</th>
                  <th>Detalle</th>
                </tr>
              </thead>
              <tbody>{"".join(ev_rows)}</tbody>
            </table>
          </div>
        '''
    else:
        critical_html = '''
          <div class="info-box green">
            <h3>Sin eventos críticos</h3>
            <p>Durante el período analizado no se detectaron microcortes mayores a 100 ms ni caídas de conexiones TCP. El enlace operó en condiciones óptimas.</p>
          </div>
        '''

    # === DIAGNOSIS ===
    diag_parts = []

    # Análisis de patrones horarios
    cuts_by_hour_local = defaultdict(int)
    for c in data["microcuts"]:
        h_local = to_local(c["timestamp"]).hour
        cuts_by_hour_local[h_local] += 1

    if cuts_by_hour_local:
        max_hour = max(cuts_by_hour_local, key=cuts_by_hour_local.get)
        max_count = cuts_by_hour_local[max_hour]
        total_cuts = sum(cuts_by_hour_local.values())
        if max_count > total_cuts * 0.25 and max_count > 5:
            diag_parts.append(f'''
              <div class="info-box yellow">
                <h3>Concentración temporal sospechosa</h3>
                <p>Se detectó una concentración de <code>{max_count} microcortes</code> a las <code>{max_hour:02d}:00 hora Colombia</code> ({(max_hour+4)%24:02d}:00 UTC). Esto representa el {max_count*100/total_cuts:.0f}% del total del día.</p>
                <p>Causas probables:</p>
                <ul>
                  <li>Proceso programado en tu red: backup, replicación de BD, snapshot.</li>
                  <li>Mantenimiento programado de un proveedor intermedio.</li>
                  <li>Job batch que satura algún enlace.</li>
                </ul>
                <p><strong>Acción recomendada</strong>: revisa qué procesos están programados a esa hora y correlaciona con logs de tus aplicaciones.</p>
              </div>
            ''')

    # Detectar cambio de ruta (latencia min cambia significativamente)
    if data["latency"] and len(data["latency"]) > 100:
        first_third = data["latency"][:len(data["latency"])//3]
        last_third = data["latency"][2*len(data["latency"])//3:]
        min1 = min(r["min_us"] for r in first_third) / 1000
        min2 = min(r["min_us"] for r in last_third) / 1000
        diff = abs(min1 - min2)
        if diff > 3:  # más de 3 ms de diferencia en el min absoluto = probable reroute
            diag_parts.append(f'''
              <div class="info-box blue">
                <h3>Cambio de ruta detectado</h3>
                <p>La latencia mínima absoluta cambió <code>{diff:.1f} ms</code> durante el día (de {min1:.1f} ms a {min2:.1f} ms). Cuando el min absoluto cambia (no solo la mediana), indica que el tráfico está tomando un <strong>camino físico distinto</strong>, no que la congestión bajó.</p>
                <p>Causas típicas: reroute BGP, failover de enlaces, activación de un path alterno por horario.</p>
                <p><strong>Para confirmar</strong>: corre <code>mtr -n -c 100 -r {data["latency"][0].get("dest", "&lt;peer&gt;")}</code> en ambos momentos del día y compara los hops.</p>
              </div>
            ''')

    # Si TCP estable pero UDP no
    if summary["total_disconnects"] == 0 and summary["total_microcuts"] > 5:
        diag_parts.append(f'''
          <div class="info-box blue">
            <h3>Por qué TCP no se cayó pero UDP sí</h3>
            <p>Tus aplicaciones TCP tradicionales (web, bases de datos, APIs) <strong>no sufrieron</strong>. TCP retransmite paquetes perdidos automáticamente y enmascara microcortes de hasta cientos de milisegundos. Sólo si la pérdida es severa y sostenida, la conexión se cae.</p>
            <p>Los microcortes UDP que vemos sí afectan aplicaciones de <strong>tiempo real</strong>:</p>
            <ul>
              <li><strong>VoIP/SIP</strong>: cortes audibles en llamadas (>50 ms = nota la diferencia).</li>
              <li><strong>Videoconferencia</strong>: frames perdidos, audio entrecortado.</li>
              <li><strong>Streaming en vivo</strong>: buffering, glitches.</li>
              <li><strong>Trading de baja latencia</strong>: oportunidades perdidas.</li>
              <li><strong>Gaming / VPN UDP</strong>: lag, desconexiones aparentes.</li>
            </ul>
          </div>
        ''')

    if not diag_parts:
        diag_parts.append('''
          <div class="info-box green">
            <h3>Red en condiciones óptimas</h3>
            <p>El análisis no detectó patrones sospechosos. Latencia estable, sin caídas TCP y pérdida UDP en valores excelentes. No se requieren acciones.</p>
          </div>
        ''')

    diagnosis_html = "".join(diag_parts)

    # === CHART DATA (JSON) ===
    # Latency time series
    lat_data = data["latency"]
    chart_labels = [to_local(r["timestamp"]).strftime("%H:%M") for r in lat_data]
    chart_data = {
        "latency": {
            "labels": chart_labels,
            "min": [r["min_us"]/1000 for r in lat_data],
            "p50": [r["p50_us"]/1000 for r in lat_data],
            "p99": [r["p99_us"]/1000 for r in lat_data],
            "max": [r["max_us"]/1000 for r in lat_data],
        },
        "cutsDist": {
            "labels": ["< 5 ms", "5-10 ms", "10-50 ms", "50-100 ms", "100-500 ms", "≥ 500 ms"],
            "values": [
                summary.get("cut_dist", {}).get("<5ms", 0),
                summary.get("cut_dist", {}).get("5-10ms", 0),
                summary.get("cut_dist", {}).get("10-50ms", 0),
                summary.get("cut_dist", {}).get("50-100ms", 0),
                summary.get("cut_dist", {}).get("100-500ms", 0),
                summary.get("cut_dist", {}).get(">=500ms", 0),
            ],
            "colors": ["#4ade80", "#86efac", "#fbbf24", "#fb923c", "#ef4444", "#dc2626"],
        },
        "cutsByHour": {
            "labels": [f"{h:02d}" for h in range(24)],
            "values": [cuts_by_hour_local.get(h, 0) for h in range(24)],
            "colors": [
                "#dc2626" if cuts_by_hour_local.get(h, 0) > 10
                else "#fb923c" if cuts_by_hour_local.get(h, 0) > 3
                else "#fbbf24" if cuts_by_hour_local.get(h, 0) > 0
                else "#374151"
                for h in range(24)
            ],
        },
        "cutsTimeline": [
            {"x": chart_labels.index(to_local(c["timestamp"]).strftime("%H:%M"))
                  if to_local(c["timestamp"]).strftime("%H:%M") in chart_labels else 0,
             "y": c["duration_ms"]}
            for c in data["microcuts"]
        ],
        "timeLabels": chart_labels,
    }

    # Sustituir placeholders
    out = HTML_TEMPLATE
    out = out.replace("__DAY__", day)
    out = out.replace("__DAY_LOCAL__", day)
    out = out.replace("__GENERATED__", datetime.now(COLOMBIA_TZ).strftime("%Y-%m-%d %H:%M:%S %Z"))
    out = out.replace("__UDP_RATE__", str(udp_rate))
    out = out.replace("__KPI_CARDS__", "".join(kpi_html))
    out = out.replace("__EXECUTIVE_SUMMARY__", exec_summary)
    out = out.replace("__HEATMAP__", heatmap_html)
    out = out.replace("__HOURLY_TABLE__", "".join(hourly_rows))
    out = out.replace("__CRITICAL_EVENTS__", critical_html)
    out = out.replace("__DIAGNOSIS__", diagnosis_html)
    out = out.replace("__CHART_DATA__", json.dumps(chart_data, default=str))

    return out


def main():
    p = argparse.ArgumentParser(description="Generador de reporte HTML netmon")
    p.add_argument("--day", required=True, help="YYYY-MM-DD (UTC)")
    p.add_argument("--base-dir", default="/var/log/netmon")
    p.add_argument("--output", default=None, help="archivo de salida (default: ./netmon-report-DAY.html)")
    p.add_argument("--udp-rate", type=int, default=1000)
    args = p.parse_args()

    data = build_data(args.base_dir, args.day)
    if not data["latency"] and not data["udp"]:
        print(f"[!] No se encontraron datos en {args.base_dir} para el día {args.day}", file=sys.stderr)
        sys.exit(1)

    html_out = render_html(data, args.day, args.base_dir, udp_rate=args.udp_rate)
    output = args.output or f"netmon-report-{args.day}.html"
    with open(output, "w", encoding="utf-8") as f:
        f.write(html_out)
    print(f"[+] Reporte generado: {output}")
    print(f"    Abre con: firefox {output}")
    print(f"    O cópialo a tu PC con: scp <server>:{os.path.abspath(output)} .")


if __name__ == "__main__":
    main()
